---
// Skills.astro

const tierOrder = {
  high: 0,
  mid: 1,
  base: 2,
};

const skills = [
  {
    label: "web",
    items: [
      { label: "HTML", tier: "high" },
      { label: "CSS", tier: "high" },
      { label: "Astro", tier: "mid" },
      { label: "PHP", tier: "mid" },
      { label: "Markdown", tier: "high" },
    ].sort((a, b) => tierOrder[a.tier] - tierOrder[b.tier]),
  },
  {
    label: "backend & datos",
    items: [
      { label: "Python", tier: "high" },
      { label: "MySQL", tier: "mid" },
      { label: "SQLite", tier: "mid" },
      { label: "tkinter", tier: "base" },
    ].sort((a, b) => tierOrder[a.tier] - tierOrder[b.tier]),
  },
  {
    label: "sistemas & devops",
    items: [
      { label: "Linux", tier: "high" },
      { label: "Bash", tier: "high" },
      { label: "Docker", tier: "high" },
      { label: "Docker Compose", tier: "high" },
      { label: "PowerShell", tier: "mid" },
      { label: "Windows Server", tier: "mid" },
      { label: "VMware", tier: "mid" },
      { label: "Graph API", tier: "base" },
      { label: "Intune", tier: "base" },
      { label: "Microsoft 365", tier: "base" },
    ].sort((a, b) => tierOrder[a.tier] - tierOrder[b.tier]),
  },
  {
    label: "herramientas & ia",
    items: [
      { label: "Git", tier: "high" },
      { label: "GitHub", tier: "high" },
      { label: "VS Code", tier: "high" },
      { label: "Copilot", tier: "mid" },
      { label: "Claude Code", tier: "mid" },
      { label: "Power Automate", tier: "base" },
      { label: "Prompting", tier: "mid" },
    ].sort((a, b) => tierOrder[a.tier] - tierOrder[b.tier]),
  },
];
---

<section class="terminal" id="skills">
  <div class="wrap">

    <!-- HEADER SUTIL -->
    <pre class="header">
<span id="typing"></span><span class="cursor">▌</span>
    </pre>

    <h2 class="title">$ skills</h2>

    <div class="box">

      {skills.map((col, i) => (
        <div class="block" style={`animation-delay:${i * 80}ms`}>
          <div class="block-title">[{col.label}]</div>

          <div class="items">
            {col.items.map((item, j) => (
              <div class="line" style={`animation-delay:${j * 25}ms`}>
                <span class={`dot dot-${item.tier}`}></span>
                <span class="name">{item.label}</span>
                <span class="tier">[{item.tier}]</span>
              </div>
            ))}
          </div>

        </div>
      ))}

    </div>
  </div>
</section>

<script is:inline>
const text = "loading skills module...";
const el = document.getElementById("typing");

let i = 0;

function type() {
  if (i < text.length) {
    el.textContent += text[i];
    i++;
    setTimeout(type, 22);
  }
}

type();
</script>

<style>
.terminal {
  font-family: var(--mono);
  color: #c8fff3;
}

/* header */
.header {
  font-size: 0.78rem;
  color: var(--muted);
  min-height: 22px;
  margin-bottom: 0.5rem;
}

.cursor {
  animation: blink 1s infinite;
  color: var(--accent);
}

@keyframes blink {
  50% { opacity: 0; }
}

.title {
  font-size: 1rem;
  margin: 1rem 0;
  color: var(--accent);
  letter-spacing: 0.05em;
}

/* container */
.box {
  border: 1px solid rgba(0,255,202,0.18);
  background: rgba(0,0,0,0.22);
  border-radius: var(--rl);
  padding: 1.3rem;
}

/* blocks */
.block {
  margin-bottom: 1.2rem;
  opacity: 0;
  transform: translateY(6px);
  animation: fadeIn 0.35s ease forwards;
}

@keyframes fadeIn {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.block-title {
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  color: var(--accent);
  margin-bottom: 0.55rem;
}

/* items */
.items {
  display: flex;
  flex-direction: column;
  gap: 0.32rem;
}

.line {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.78rem;

  opacity: 0;
  animation: fadeIn 0.25s ease forwards;
}

.name {
  flex: 1;
}

/* dot */
.dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
}

.dot-high { background: var(--accent); }
.dot-mid { background: rgba(0,255,202,0.5); }
.dot-base { background: rgba(255,255,255,0.25); }

/* tier text subtle */
.tier {
  font-size: 0.65rem;
  opacity: 0.45;
}

.high .name { color: #e6fffb; }
.mid .name { color: #b8d4d0; }
.base .name { color: rgba(255,255,255,0.6); }
</style>