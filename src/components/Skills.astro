---
const tierOrder = {
  high: 0,
  mid: 1,
  base: 2,
};

const skills = [
  {
    label: "web",
    items: [
      { label: "HTML", tier: "high" },
      { label: "CSS", tier: "high" },
      { label: "Astro", tier: "mid" },
      { label: "PHP", tier: "mid" },
      { label: "Markdown", tier: "high" },
    ].sort((a, b) => tierOrder[a.tier] - tierOrder[b.tier]),
  },
  {
    label: "backend & datos",
    items: [
      { label: "Python", tier: "high" },
      { label: "MySQL", tier: "mid" },
      { label: "SQLite", tier: "mid" },
      { label: "tkinter", tier: "base" },
    ].sort((a, b) => tierOrder[a.tier] - tierOrder[b.tier]),
  },
  {
    label: "sistemas & devops",
    items: [
      { label: "Linux", tier: "high" },
      { label: "Bash", tier: "high" },
      { label: "Docker", tier: "high" },
      { label: "Docker Compose", tier: "high" },
      { label: "PowerShell", tier: "mid" },
      { label: "Windows Server", tier: "mid" },
      { label: "VMware", tier: "mid" },
      { label: "Graph API", tier: "base" },
      { label: "Intune", tier: "base" },
      { label: "Microsoft 365", tier: "base" },
    ].sort((a, b) => tierOrder[a.tier] - tierOrder[b.tier]),
  },
  {
    label: "herramientas & ia",
    items: [
      { label: "Git", tier: "high" },
      { label: "GitHub", tier: "high" },
      { label: "VS Code", tier: "high" },
      { label: "Copilot", tier: "mid" },
      { label: "Claude Code", tier: "mid" },
      { label: "Power Automate", tier: "base" },
      { label: "Prompting", tier: "mid" },
    ].sort((a, b) => tierOrder[a.tier] - tierOrder[b.tier]),
  },
];
---

<section id="skills" class="skills">
  <div class="wrap">

    <pre class="header">
<span class="cmd">$ skills --list</span>
<span class="status">system: ready</span>
    </pre>

    <h2 class="title">Skills</h2>

    <div class="grid">

      {skills.map((col) => (
        <div class="card">

          <div class="card-title">
            [{col.label}]
          </div>

          <div class="items">
            {col.items.map((item) => (
              <div class={`row ${item.tier}`}>
                <span class={`dot ${item.tier}`}></span>
                <span class="name">{item.label}</span>
                <span class="tag">{item.tier}</span>
              </div>
            ))}
          </div>

        </div>
      ))}

    </div>

  </div>
</section>

<style>
.skills {
  font-family: var(--mono);
  color: #e6fffb;
}

/* HEADER LIMPIO */
.header {
  display: flex;
  justify-content: space-between;
  font-size: 0.78rem;
  margin-bottom: 1.2rem;
  color: var(--muted);
}

.cmd {
  color: var(--accent);
}

.status {
  color: rgba(0,255,202,0.7);
}

/* TITULO */
.title {
  font-size: 1rem;
  margin-bottom: 1.4rem;
  color: var(--accent);
  letter-spacing: 0.05em;
}

/* GRID tipo dashboard */
.grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1rem;
}

/* CARD limpia */
.card {
  padding: 1.2rem;
  border-radius: var(--rl);
  border: 1px solid rgba(0,255,202,0.15);
  background: rgba(0,0,0,0.18);
  transition: transform 0.2s ease, border-color 0.2s ease;
}

.card:hover {
  transform: translateY(-2px);
  border-color: rgba(0,255,202,0.35);
}

/* HEADER DE BLOQUE */
.card-title {
  font-size: 0.7rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 0.9rem;
  opacity: 0.9;
}

/* FILAS (ya no “lista”, ahora “rows”) */
.items {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}

.row {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.78rem;
  padding: 0.15rem 0;
}

/* DOT */
.dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
}

/* TEXTO */
.name {
  flex: 1;
}

.tag {
  font-size: 0.6rem;
  opacity: 0.45;
  text-transform: uppercase;
}

/* TIERS equilibrados (PRO UX) */
.high .name { color: #eafffb; }
.mid .name { color: #b8d4d0; }
.base .name { color: rgba(255,255,255,0.65); }

.high .tag { color: var(--accent); }
.mid .tag { color: rgba(0,255,202,0.6); }
.base .tag { color: rgba(255,255,255,0.35); }

.dot.high { background: var(--accent); }
.dot.mid { background: rgba(0,255,202,0.5); }
.dot.base { background: rgba(255,255,255,0.25); }
</style>