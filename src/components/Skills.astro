---
// Skills.astro (terminal mode)

const tierOrder = {
  high: 0,
  mid: 1,
  base: 2,
};

const skills = [
  {
    label: "web",
    items: [
      { label: "HTML", tier: "high" },
      { label: "CSS", tier: "high" },
      { label: "Astro", tier: "mid" },
      { label: "PHP", tier: "mid" },
      { label: "Markdown", tier: "high" },
    ].sort((a, b) => tierOrder[a.tier] - tierOrder[b.tier]),
  },
  {
    label: "backend & datos",
    items: [
      { label: "Python", tier: "high" },
      { label: "MySQL", tier: "mid" },
      { label: "SQLite", tier: "mid" },
      { label: "tkinter", tier: "base" },
    ].sort((a, b) => tierOrder[a.tier] - tierOrder[b.tier]),
  },
  {
    label: "sistemas & devops",
    items: [
      { label: "Linux", tier: "high" },
      { label: "Bash", tier: "high" },
      { label: "Docker", tier: "high" },
      { label: "Docker Compose", tier: "high" },
      { label: "PowerShell", tier: "mid" },
      { label: "Windows Server", tier: "mid" },
      { label: "VMware", tier: "mid" },
      { label: "Graph API", tier: "base" },
      { label: "Intune", tier: "base" },
      { label: "Microsoft 365", tier: "base" },
    ].sort((a, b) => tierOrder[a.tier] - tierOrder[b.tier]),
  },
  {
    label: "herramientas & ia",
    items: [
      { label: "Git", tier: "high" },
      { label: "GitHub", tier: "high" },
      { label: "VS Code", tier: "high" },
      { label: "Copilot", tier: "mid" },
      { label: "Claude Code", tier: "mid" },
      { label: "Power Automate", tier: "base" },
      { label: "Prompting", tier: "mid" },
    ].sort((a, b) => tierOrder[a.tier] - tierOrder[b.tier]),
  },
];
---

<section id="habilidades" class="terminal">
  <div class="wrap">

    <pre class="terminal-header">
&gt; skills --scan
&gt; loading modules...
&gt; status: OK
    </pre>

    <h2 class="title">$ cat skills.log</h2>

    <div class="terminal-box">
      {skills.map((col) => (
        <div class="block">
          <div class="block-header">
            [{col.label.toUpperCase()}]
          </div>

          <div class="block-content">
            {col.items.map((item) => (
              <div class={`line ${item.tier}`}>
                <span class="prompt">&gt;</span>
                <span class="name">{item.label}</span>
                <span class="tier">[{item.tier}]</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <pre class="footer">
scan complete — no errors detected ✔
    </pre>

  </div>
</section>

<style>
.terminal {
  font-family: var(--mono);
  color: #c8fff3;
}

.terminal-header {
  color: var(--muted);
  font-size: 0.8rem;
  margin-bottom: 1.5rem;
  line-height: 1.4;
}

.title {
  font-size: 1rem;
  margin-bottom: 1.2rem;
  color: var(--accent);
  letter-spacing: 0.08em;
}

.terminal-box {
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
  border: 1px solid rgba(0,255,202,0.25);
  padding: 1.5rem;
  border-radius: var(--rl);
  background: rgba(0,0,0,0.25);
  backdrop-filter: blur(8px);
}

.block-header {
  font-size: 0.75rem;
  color: var(--accent);
  margin-bottom: 0.6rem;
  letter-spacing: 0.12em;
}

.block-content {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}

.line {
  display: flex;
  gap: 0.6rem;
  font-size: 0.78rem;
  align-items: center;
}

.prompt {
  color: var(--accent);
}

.name {
  flex: 1;
  color: #d7fff7;
}

.tier {
  font-size: 0.65rem;
  opacity: 0.7;
}

/* TIER STYLING */
.high .name { color: #d7fff7; }
.mid .name { color: #a9d6cf; }
.base .name { color: rgba(255,255,255,0.55); }

.high .tier { color: var(--accent); }
.mid .tier { color: rgba(0,255,202,0.6); }
.base .tier { color: rgba(255,255,255,0.35); }

.line:hover {
  background: rgba(0,255,202,0.06);
  padding-left: 0.3rem;
  border-left: 2px solid var(--accent);
}

.footer {
  margin-top: 1.5rem;
  color: rgba(0,255,202,0.6);
  font-size: 0.75rem;
}
</style>