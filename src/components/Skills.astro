---
// Skills.astro
const skills = [
  {
    label: "🌐 web",
    items: [
      { label: "HTML", level: 95 },
      { label: "CSS", level: 92 },
      { label: "Astro", level: 65 },
      { label: "PHP", level: 80 },
      { label: "Markdown", level: 90 },
    ],
  },
  {
    label: "🧠 backend & datos",
    items: [
      { label: "Python", level: 85 },
      { label: "MySQL", level: 82 },
      { label: "SQLite", level: 72 },
      { label: "tkinter", level: 55 },
    ],
  },
  {
    label: "🖥️ sistemas & devops",
    items: [
      { label: "Linux", level: 90 },
      { label: "PowerShell", level: 78 },
      { label: "Docker", level: 85 },
      { label: "Bash", level: 87 },
      { label: "Windows Server", level: 72 },
      { label: "Graph API", level: 55 },
      { label: "Intune", level: 55 },
      { label: "VMware", level: 70 },
      { label: "Docker Compose", level: 85 },
      { label: "Microsoft 365", level: 65 },
    ],
  },
  {
    label: "🛠️ herramientas",
    items: [
      { label: "Git", level: 92 },
      { label: "GitHub", level: 90 },
      { label: "VS Code", level: 95 },
      { label: "Power Automate", level: 55 },
    ],
  },
];
---

<section id="habilidades" class="section">
  <div class="wrap">
    <span class="sec-label">// 03</span>
    <h2 class="sec-title">Habilidades</h2>
    <p class="sec-sub">Tecnologías con las que trabajo de verdad.</p>

    <div class="skills-grid">
      {skills.map((col) => (
        <div class="skill-block">
          <span class="skill-label">{col.label}</span>
          <div class="skill-items">
            {col.items.map((item) => (
              <div class="skill-item">
                <div class="skill-header">
                  <span class="skill-name">{item.label}</span>
                  <span class="skill-level">{item.level}%</span>
                </div>
                <div class="skill-bar">
                  <div class="skill-fill" style={`width: ${item.level}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
