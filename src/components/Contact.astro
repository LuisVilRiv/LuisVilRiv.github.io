---
// Contact.astro
---

<section id="contacto" class="section section-dark">
  <div class="wrap">
    <span class="sec-label">// 04</span>
    <h2 class="sec-title">Contacto</h2>
    <p class="sec-sub">
      Si tienes una oportunidad de FCT o simplemente quieres hablar de un proyecto.
    </p>

    <div class="contact-grid">

      <!-- LINKS -->
      <div class="contact-links">

        <a href="mailto:villegasriveraluis@gmail.com" class="contact-link">
          <span class="cl-label">email</span>
          <span class="cl-val">villegasriveraluis@gmail.com</span>
        </a>

        <a href="https://wa.me/34635138578" target="_blank" class="contact-link">
          <span class="cl-label">whatsapp</span>
          <span class="cl-val">+34 635 13 85 78</span>
        </a>

        <a href="https://github.com/LuisVilRiv" target="_blank" class="contact-link">
          <span class="cl-label">github</span>
          <span class="cl-val">LuisVilRiv</span>
        </a>

        <a href="https://www.linkedin.com/in/luis-villegas-rivera/" target="_blank" class="contact-link">
          <span class="cl-label">linkedin</span>
          <span class="cl-val">luis-villegas-rivera</span>
        </a>

        <div class="contact-link" style="cursor:default">
          <span class="cl-label">ubicación</span>
          <span class="cl-val">Granada, España</span>
        </div>

      </div>

      <!-- FORM -->
      <form class="contact-form" id="contactForm">

        <div class="field">
          <label>Nombre</label>
          <input name="nombre" type="text" required />
        </div>

        <div class="field">
          <label>Email</label>
          <input name="email" type="email" required />
        </div>

        <div class="field">
          <label>Mensaje</label>
          <textarea name="mensaje" rows="5" required></textarea>
        </div>

        <!-- LINK SMART -->
        <div class="field">
          <label>Archivo o proyecto (opcional)</label>

          <div class="link-input-wrapper" id="linkWrapper">
            <span id="linkIcon" class="link-icon">🔗</span>

            <input
              id="linkInput"
              name="archivo_link"
              type="url"
              placeholder="https://github.com/... o drive/dropbox"
            />

            <button type="button" id="clearLink" class="clear-link">✕</button>
          </div>

          <div id="linkPreview" class="link-preview hidden"></div>

          <span class="field-hint">
            Se detecta automáticamente GitHub, Drive, Dropbox…
          </span>
        </div>

        <button id="submitBtn" type="submit" class="btn btn-full">
          Enviar mensaje
        </button>

        <p id="status" class="form-status"></p>

      </form>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contactForm");
  const btn = document.getElementById("submitBtn");
  const status = document.getElementById("status");

  const input = document.getElementById("linkInput");
  const preview = document.getElementById("linkPreview");
  const icon = document.getElementById("linkIcon");
  const wrapper = document.getElementById("linkWrapper");
  const clearBtn = document.getElementById("clearLink");

  function detectPlatform(url) {
    if (url.includes("github.com")) return { name: "GitHub", icon: "🐙" };
    if (url.includes("drive.google.com")) return { name: "Google Drive", icon: "📁" };
    if (url.includes("dropbox.com")) return { name: "Dropbox", icon: "🧊" };
    if (url.includes("notion.so")) return { name: "Notion", icon: "📝" };
    if (url.includes("figma.com")) return { name: "Figma", icon: "🎨" };
    return { name: "Enlace", icon: "🔗" };
  }

  function isValidURL(str) {
    try {
      new URL(str);
      return true;
    } catch {
      return false;
    }
  }

  input.addEventListener("input", () => {
    const url = input.value.trim();

    if (!url) {
      preview.classList.add("hidden");
      wrapper.classList.remove("valid", "invalid");
      icon.textContent = "🔗";
      return;
    }

    if (!isValidURL(url)) {
      wrapper.classList.add("invalid");
      wrapper.classList.remove("valid");
      preview.classList.add("hidden");
      icon.textContent = "⚠️";
      return;
    }

    const platform = detectPlatform(url);

    wrapper.classList.add("valid");
    wrapper.classList.remove("invalid");
    icon.textContent = platform.icon;

    preview.classList.remove("hidden");
    preview.innerHTML = `
      <span class="lp-icon">${platform.icon}</span>
      <div class="lp-meta">
        <strong>${platform.name}</strong>
        <a href="${url}" target="_blank">${url}</a>
      </div>
    `;
  });

  clearBtn.addEventListener("click", () => {
    input.value = "";
    preview.classList.add("hidden");
    wrapper.classList.remove("valid", "invalid");
    icon.textContent = "🔗";
  });

  // SUBMIT CON TU REDIRECCIÓN
  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    btn.disabled = true;
    btn.textContent = "Enviando...";

    const formData = new FormData(form);

    try {
      const res = await fetch("https://formspree.io/f/xlgaejzd", {
        method: "POST",
        body: formData,
        headers: { Accept: "application/json" }
      });

      if (res.ok) {
        window.location.href = "/gracias"; // 👈 TU REDIRECCIÓN
      } else {
        status.textContent = "Error al enviar";
      }
    } catch {
      status.textContent = "Error de conexión";
    }

    btn.disabled = false;
    btn.textContent = "Enviar mensaje";
  });
</script>