---
// Contact.astro
---

<section id="contacto" class="section section-dark">
  <div class="wrap">
    <span class="sec-label">// 04</span>
    <h2 class="sec-title">Contacto</h2>
    <p class="sec-sub">Si tienes una oportunidad de FCT o simplemente quieres hablar de un proyecto.</p>

    <div class="contact-grid">

      <!-- LINKS -->
      <div class="contact-links">
        <a href="mailto:villegasriveraluis@gmail.com" class="contact-link">
          <span class="cl-label">email</span>
          <span class="cl-val">villegasriveraluis@gmail.com</span>
        </a>

        <a href="https://github.com/LuisVilRiv" target="_blank" class="contact-link">
          <span class="cl-label">github</span>
          <span class="cl-val">LuisVilRiv</span>
        </a>

        <a href="https://www.linkedin.com/in/luis-villegas-rivera/" target="_blank" class="contact-link">
          <span class="cl-label">linkedin</span>
          <span class="cl-val">luis-villegas-rivera</span>
        </a>

        <div class="contact-link" style="cursor:default">
          <span class="cl-label">ubicación</span>
          <span class="cl-val">Granada, España</span>
        </div>
      </div>

      <!-- FORM -->
      <form class="contact-form" id="contactForm" enctype="multipart/form-data">

        <div class="field">
          <label>Nombre</label>
          <input name="nombre" type="text" required />
        </div>

        <div class="field">
          <label>Email</label>
          <input name="email" type="email" required />
        </div>

        <div class="field">
          <label>Mensaje</label>
          <textarea name="mensaje" rows="5" required></textarea>
        </div>

        <!-- DROPZONE -->
        <div class="field">
          <label>Archivo (opcional)</label>

          <div id="dropzone" class="dropzone">
            <input id="fileInput" name="archivo" type="file" hidden />

            <div class="dz-content">
              <div class="dz-icon">📁</div>
              <div class="dz-text">
                <strong>Arrastra aquí o haz click</strong>
                <span>PDF, imagen o documento</span>
              </div>
            </div>

            <div id="filePreview" class="file-preview hidden"></div>
          </div>
        </div>

        <!-- PROGRESS -->
        <div id="progressWrap" class="progress hidden">
          <div id="progressBar" class="progress-bar"></div>
        </div>

        <button id="submitBtn" type="submit" class="btn btn-full">
          Enviar mensaje
        </button>

        <p id="status" class="form-status"></p>
      </form>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contactForm");
  const dropzone = document.getElementById("dropzone");
  const fileInput = document.getElementById("fileInput");
  const filePreview = document.getElementById("filePreview");

  const status = document.getElementById("status");
  const btn = document.getElementById("submitBtn");

  const progressWrap = document.getElementById("progressWrap");
  const progressBar = document.getElementById("progressBar");

  // -------------------------
  // OPEN FILE
  // -------------------------
  dropzone.addEventListener("click", () => fileInput.click());

  // -------------------------
  // DRAG & DROP
  // -------------------------
  dropzone.addEventListener("dragover", (e) => {
    e.preventDefault();
    dropzone.classList.add("drag");
  });

  dropzone.addEventListener("dragleave", () => {
    dropzone.classList.remove("drag");
  });

  dropzone.addEventListener("drop", (e) => {
    e.preventDefault();
    dropzone.classList.remove("drag");

    fileInput.files = e.dataTransfer.files;
    renderFile();
  });

  fileInput.addEventListener("change", renderFile);

  // -------------------------
  // FILE PREVIEW
  // -------------------------
  function renderFile() {
    const file = fileInput.files[0];
    if (!file) return;

    filePreview.classList.remove("hidden");

    const removeBtn = `
      <button type="button" class="remove-file" id="removeFile">
        remove
      </button>
    `;

    if (file.type.startsWith("image/")) {
      const reader = new FileReader();

      reader.onload = (e) => {
        filePreview.innerHTML = `
          <img src="${e.target.result}" />
          <span>${file.name}</span>
          ${removeBtn}
        `;
        attachRemove();
      };

      reader.readAsDataURL(file);
    } else {
      filePreview.innerHTML = `
        <div class="file-icon">📄</div>
        <span>${file.name}</span>
        ${removeBtn}
      `;
      attachRemove();
    }
  }

  function attachRemove() {
    const btnRemove = document.getElementById("removeFile");

    btnRemove.addEventListener("click", (e) => {
      e.stopPropagation();

      fileInput.value = "";
      filePreview.classList.add("hidden");
      filePreview.innerHTML = "";
    });
  }

  // -------------------------
  // SUBMIT (XHR + progress)
  // -------------------------
  form.addEventListener("submit", (e) => {
    e.preventDefault();

    btn.disabled = true;
    btn.textContent = "Enviando...";

    progressWrap.classList.remove("hidden");
    progressBar.style.width = "0%";

    const formData = new FormData(form);

    const xhr = new XMLHttpRequest();
    xhr.open("POST", "https://formspree.io/f/xlgaejzd");
    xhr.setRequestHeader("Accept", "application/json");

    xhr.upload.onprogress = (e) => {
      if (e.lengthComputable) {
        const percent = (e.loaded / e.total) * 100;
        progressBar.style.width = percent + "%";
      }
    };

    xhr.onload = () => {
      if (xhr.status === 200) {
        status.textContent = "✅ Mensaje enviado correctamente";
        status.style.color = "#4ade80";
        form.reset();

        filePreview.classList.add("hidden");
        filePreview.innerHTML = "";
      } else {
        status.textContent = "❌ Error al enviar";
        status.style.color = "#f87171";
      }

      btn.disabled = false;
      btn.textContent = "Enviar mensaje";
      progressWrap.classList.add("hidden");
    };

    xhr.onerror = () => {
      status.textContent = "❌ Error de conexión";
      status.style.color = "#f87171";

      btn.disabled = false;
      btn.textContent = "Enviar mensaje";
      progressWrap.classList.add("hidden");
    };

    xhr.send(formData);
  });
</script>

<style>
.dropzone {
  border: 1px dashed rgba(255,255,255,0.2);
  border-radius: 12px;
  padding: 16px;
  cursor: pointer;
  transition: 0.2s;
  background: rgba(255,255,255,0.02);
}

.dropzone.drag {
  border-color: #4ade80;
  background: rgba(74,222,128,0.08);
}

.dz-content {
  display: flex;
  gap: 12px;
  align-items: center;
}

.dz-icon {
  font-size: 20px;
}

.dz-text span {
  font-size: 12px;
  opacity: 0.6;
  display: block;
}

.file-preview {
  margin-top: 10px;
  display: flex;
  gap: 10px;
  align-items: center;
}

.file-preview img {
  width: 40px;
  height: 40px;
  border-radius: 6px;
  object-fit: cover;
}

.hidden {
  display: none;
}

.remove-file {
  margin-left: auto;
  background: transparent;
  border: 1px solid rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.7);
  border-radius: 8px;
  padding: 4px 10px;
  font-size: 11px;
  cursor: pointer;
  transition: 0.2s;
  letter-spacing: 0.5px;
  text-transform: lowercase;
}

.remove-file:hover {
  border-color: rgba(255,255,255,0.35);
  color: white;
  background: rgba(255,255,255,0.04);
  transform: translateY(-1px);
}

.progress {
  height: 4px;
  background: rgba(255,255,255,0.1);
  border-radius: 999px;
  overflow: hidden;
  margin: 10px 0;
}

.progress-bar {
  height: 100%;
  width: 0%;
  background: #4ade80;
  transition: width 0.2s;
}
</style>