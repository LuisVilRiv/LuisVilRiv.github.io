---
// Contact.astro
---

<section id="contacto" class="section section-dark">
  <div class="wrap">
    <span class="sec-label">// 04</span>
    <h2 class="sec-title">Contacto</h2>
    <p class="sec-sub">Si tienes una oportunidad de FCT o simplemente quieres hablar de un proyecto.</p>

    <div class="contact-grid">
      <div class="contact-links">
        <a href="mailto:villegasriveraluis@gmail.com" class="contact-link">
          <span class="cl-label">email</span>
          <span class="cl-val">villegasriveraluis@gmail.com</span>
        </a>

        <a href="https://github.com/LuisVilRiv" target="_blank" rel="noopener noreferrer" class="contact-link">
          <span class="cl-label">github</span>
          <span class="cl-val">LuisVilRiv</span>
        </a>

        <a href="https://www.linkedin.com/in/luis-villegas-rivera/" target="_blank" rel="noopener noreferrer" class="contact-link">
          <span class="cl-label">linkedin</span>
          <span class="cl-val">luis-villegas-rivera</span>
        </a>

        <div class="contact-link" style="cursor:default">
          <span class="cl-label">ubicación</span>
          <span class="cl-val">Granada, España</span>
        </div>
      </div>

      <!-- FORM -->
      <form class="contact-form" id="contactForm" enctype="multipart/form-data">
        <div class="field">
          <label for="nombre">Nombre</label>
          <input id="nombre" name="nombre" type="text" placeholder="Tu nombre" required />
        </div>

        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" placeholder="tu@email.com" required />
        </div>

        <div class="field">
          <label for="mensaje">Mensaje</label>
          <textarea id="mensaje" name="mensaje" rows="5" placeholder="De qué va..." required></textarea>
        </div>

        <div class="field">
          <label for="archivo">Archivo (opcional)</label>
          <input id="archivo" name="archivo" type="file" />
        </div>

        <button type="submit" class="btn btn-full" id="submitBtn">
          Enviar mensaje
        </button>

        <p id="formStatus" class="form-status"></p>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contactForm");
  const status = document.getElementById("formStatus");
  const button = document.getElementById("submitBtn");

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    button.disabled = true;
    button.textContent = "Enviando...";

    const formData = new FormData(form);

    try {
      const response = await fetch("https://formspree.io/f/xlgaejzd", {
        method: "POST",
        body: formData,
        headers: {
          Accept: "application/json",
        },
      });

      if (response.ok) {
        status.textContent = "✅ Mensaje enviado correctamente";
        status.style.color = "#4ade80";
        form.reset();
      } else {
        status.textContent = "❌ Error al enviar. Inténtalo de nuevo.";
        status.style.color = "#f87171";
      }
    } catch (error) {
      status.textContent = "❌ Error de conexión.";
      status.style.color = "#f87171";
    }

    button.disabled = false;
    button.textContent = "Enviar mensaje";
  });
</script>