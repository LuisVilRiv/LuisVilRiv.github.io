---
// Contact.astro
---

<section id="contacto" class="section section-dark">
  <div class="wrap">
    <span class="sec-label">// 04</span>
    <h2 class="sec-title">Contacto</h2>
    <p class="sec-sub">Si tienes una oportunidad de FCT o simplemente quieres hablar de un proyecto.</p>

    <div class="contact-grid">

      <!-- LINKS -->
      <div class="contact-links">

        <a href="mailto:villegasriveraluis@gmail.com" class="contact-link">
          <span class="cl-label">email</span>
          <span class="cl-val">villegasriveraluis@gmail.com</span>
        </a>

        <a
          href="https://wa.me/34635138578"
          target="_blank"
          class="contact-link"
          rel="noopener noreferrer"
        >
          <span class="cl-label">whatsapp</span>
          <span class="cl-val">+34 635 13 85 78</span>
        </a>

        <a href="https://github.com/LuisVilRiv" target="_blank" class="contact-link">
          <span class="cl-label">github</span>
          <span class="cl-val">LuisVilRiv</span>
        </a>

        <a href="https://www.linkedin.com/in/luis-villegas-rivera/" target="_blank" class="contact-link">
          <span class="cl-label">linkedin</span>
          <span class="cl-val">luis-villegas-rivera</span>
        </a>

        <div class="contact-link" style="cursor:default">
          <span class="cl-label">ubicación</span>
          <span class="cl-val">Granada, España</span>
        </div>

      </div>

      <!-- FORM -->
      <form class="contact-form" id="contactForm" enctype="multipart/form-data">

        <div class="field">
          <label>Nombre</label>
          <input name="nombre" type="text" required />
        </div>

        <div class="field">
          <label>Email</label>
          <input name="email" type="email" required />
        </div>

        <div class="field">
          <label>Mensaje</label>
          <textarea name="mensaje" rows="5" required></textarea>
        </div>

        <!-- DROPZONE -->
        <div class="field">
          <label>Archivo (opcional)</label>

          <div id="dropzone" class="dropzone">
            <input id="fileInput" name="archivo" type="file" hidden />

            <div class="dz-content">
              <div class="dz-icon">📎</div>
              <div class="dz-text">
                <strong>Arrastra o haz click para subir</strong>
                <span>PDF, imagen o documento</span>
              </div>
            </div>

            <div id="filePreview" class="file-preview hidden"></div>
          </div>
        </div>

        <button id="submitBtn" type="submit" class="btn btn-full">
          Enviar mensaje
        </button>

        <p id="status" class="form-status"></p>
      </form>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contactForm");
  const dropzone = document.getElementById("dropzone");
  const fileInput = document.getElementById("fileInput");
  const filePreview = document.getElementById("filePreview");

  const status = document.getElementById("status");
  const btn = document.getElementById("submitBtn");

  // OPEN FILE
  dropzone.addEventListener("click", () => fileInput.click());

  // DRAG
  dropzone.addEventListener("dragover", (e) => {
    e.preventDefault();
    dropzone.classList.add("drag");
  });

  dropzone.addEventListener("dragleave", () => {
    dropzone.classList.remove("drag");
  });

  dropzone.addEventListener("drop", (e) => {
    e.preventDefault();
    dropzone.classList.remove("drag");

    fileInput.files = e.dataTransfer.files;
    renderFile();
  });

  fileInput.addEventListener("change", renderFile);

  // FILE RENDER
  function renderFile() {
    const file = fileInput.files[0];
    if (!file) return;

    filePreview.classList.remove("hidden");

    const removeIcon = `
      <button type="button" class="remove-file" id="removeFile" aria-label="remove">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    `;

    if (file.type.startsWith("image/")) {
      const reader = new FileReader();
      reader.onload = (e) => {
        filePreview.innerHTML = `
          <img src="${e.target.result}" />
          <span>${file.name}</span>
          ${removeIcon}
        `;
        attachRemove();
      };
      reader.readAsDataURL(file);
    } else {
      filePreview.innerHTML = `
        <div class="file-icon">📄</div>
        <span>${file.name}</span>
        ${removeIcon}
      `;
      attachRemove();
    }
  }

  function attachRemove() {
    document.getElementById("removeFile").addEventListener("click", (e) => {
      e.stopPropagation();

      fileInput.value = "";
      filePreview.classList.add("hidden");
      filePreview.innerHTML = "";
    });
  }

  // SUBMIT
  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    btn.disabled = true;
    btn.textContent = "Enviando...";

    const formData = new FormData(form);

    try {
      const res = await fetch("https://formspree.io/f/xlgaejzd", {
        method: "POST",
        body: formData,
        headers: { Accept: "application/json" }
      });

      if (res.ok) {
        status.textContent = "✓ Mensaje enviado";
        status.style.color = "#4ade80";
        form.reset();
        filePreview.classList.add("hidden");
        filePreview.innerHTML = "";
      } else {
        status.textContent = "Error al enviar";
        status.style.color = "#f87171";
      }
    } catch {
      status.textContent = "Error de conexión";
      status.style.color = "#f87171";
    }

    btn.disabled = false;
    btn.textContent = "Enviar mensaje";
  });
</script>

<style>
.dropzone {
  border: 1px dashed rgba(255,255,255,0.15);
  border-radius: 12px;
  padding: 14px;
  cursor: pointer;
  transition: 0.2s ease;
  background: rgba(255,255,255,0.02);
}

.dropzone.drag {
  border-color: rgba(74,222,128,0.7);
  background: rgba(74,222,128,0.06);
}

.dz-content {
  display: flex;
  gap: 12px;
  align-items: center;
}

.dz-icon {
  opacity: 0.7;
}

.dz-text strong {
  display: block;
  font-size: 13px;
}

.dz-text span {
  font-size: 11px;
  opacity: 0.5;
}

.file-preview {
  margin-top: 10px;
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 10px;
  border-radius: 10px;
  background: rgba(255,255,255,0.03);
}

.file-preview img {
  width: 34px;
  height: 34px;
  border-radius: 6px;
  object-fit: cover;
}

.file-icon {
  opacity: 0.7;
}

/* REMOVE BUTTON (SENIOR UX) */
.remove-file {
  margin-left: auto;
  opacity: 0;
  border: none;
  background: transparent;
  color: rgba(255,255,255,0.4);
  cursor: pointer;
  padding: 4px;
  border-radius: 6px;
  transition: all 0.15s ease;
}

.file-preview:hover .remove-file {
  opacity: 1;
}

.remove-file:hover {
  color: white;
  background: rgba(255,255,255,0.06);
  transform: scale(1.05);
}
</style>