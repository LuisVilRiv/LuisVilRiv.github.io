---
// Contact.astro
---

<section id="contacto" class="section section-dark">
  <div class="wrap">
    <span class="sec-label">// 04</span>
    <h2 class="sec-title">Contacto</h2>
    <p class="sec-sub">
      Si tienes una oportunidad de FCT o simplemente quieres hablar de un proyecto.
    </p>

    <div class="contact-grid">

      <!-- LINKS -->
      <div class="contact-links">

        <a href="mailto:villegasriveraluis@gmail.com" class="contact-link">
          <span class="cl-label">email</span>
          <span class="cl-val">villegasriveraluis@gmail.com</span>
        </a>

        <a href="https://wa.me/34635138578" target="_blank" rel="noopener noreferrer nofollow external" referrerpolicy="no-referrer" class="contact-link">
          <span class="cl-label">whatsapp</span>
          <span class="cl-val">+34 635 13 85 78</span>
        </a>

        <a href="https://github.com/LuisVilRiv" target="_blank" rel="noopener noreferrer nofollow external" referrerpolicy="no-referrer" class="contact-link">
          <span class="cl-label">github</span>
          <span class="cl-val">LuisVilRiv</span>
        </a>

        <a href="https://www.linkedin.com/in/luis-villegas-rivera/" target="_blank" rel="noopener noreferrer nofollow external" referrerpolicy="no-referrer" class="contact-link">
          <span class="cl-label">linkedin</span>
          <span class="cl-val">luis-villegas-rivera</span>
        </a>

        <div class="contact-link" style="cursor:default">
          <span class="cl-label">ubicación</span>
          <span class="cl-val">Granada, España</span>
        </div>

      </div>

      <!-- FORM -->
      <form class="contact-form" id="contactForm" action="https://formspree.io/f/xlgaejzd" method="POST">

        <div class="field">
          <label for="nombre">Nombre</label>
          <input id="nombre" name="nombre" type="text" required autocomplete="name" />
        </div>

        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required autocomplete="email" />
        </div>

        <div class="field">
          <label for="mensaje">Mensaje</label>
          <textarea id="mensaje" name="mensaje" rows="5" required></textarea>
        </div>

        <!-- LINK INTELIGENTE -->
        <div class="field">
          <label for="linkInput">Archivo o proyecto (opcional)</label>

          <div class="link-input-wrapper" id="linkWrapper">
            <span id="linkIcon" class="link-icon">🔗</span>

            <input
              id="linkInput"
              name="archivo_link"
              type="url"
              placeholder="https://github.com/... o drive/dropbox"
            />

            <button type="button" id="clearLink" class="clear-link" aria-label="Limpiar enlace">✕</button>
          </div>

          <div id="linkPreview" class="link-preview hidden"></div>

          <span class="field-hint">
            Se detecta automáticamente GitHub, Drive, Dropbox…
          </span>
        </div>

        <button id="submitBtn" type="submit" class="btn btn-full">
          Enviar mensaje
        </button>

        <p id="status" class="form-status"></p>

      </form>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contactForm") as HTMLFormElement | null;
  const btn = document.getElementById("submitBtn") as HTMLButtonElement | null;
  const status = document.getElementById("status") as HTMLParagraphElement | null;

  const input = document.getElementById("linkInput") as HTMLInputElement | null;
  const preview = document.getElementById("linkPreview") as HTMLDivElement | null;
  const icon = document.getElementById("linkIcon") as HTMLSpanElement | null;
  const wrapper = document.getElementById("linkWrapper") as HTMLDivElement | null;
  const clearBtn = document.getElementById("clearLink") as HTMLButtonElement | null;

  function detectPlatform(url: string) {
    if (url.includes("github.com")) return { name: "GitHub", icon: "🐙" };
    if (url.includes("drive.google.com")) return { name: "Google Drive", icon: "📁" };
    if (url.includes("dropbox.com")) return { name: "Dropbox", icon: "🧊" };
    if (url.includes("notion.so")) return { name: "Notion", icon: "📝" };
    if (url.includes("figma.com")) return { name: "Figma", icon: "🎨" };
    return { name: "Enlace", icon: "🔗" };
  }

  function isValidURL(str: string) {
    try {
      new URL(str);
      return true;
    } catch {
      return false;
    }
  }

  if (!form || !btn || !status || !input || !preview || !icon || !wrapper || !clearBtn) {
    throw new Error("No se pudo inicializar el formulario de contacto.");
  }

  input.addEventListener("input", () => {
    const url = input.value.trim();

    if (!url) {
      preview.classList.add("hidden");
      wrapper.classList.remove("valid", "invalid");
      icon.textContent = "🔗";
      return;
    }

    if (!isValidURL(url)) {
      wrapper.classList.add("invalid");
      wrapper.classList.remove("valid");
      preview.classList.add("hidden");
      icon.textContent = "⚠️";
      return;
    }

    const platform = detectPlatform(url);

    wrapper.classList.add("valid");
    wrapper.classList.remove("invalid");
    icon.textContent = platform.icon;

    preview.classList.remove("hidden");
    preview.innerHTML = `
      <span class="lp-icon">${platform.icon}</span>
      <div class="lp-meta">
        <strong>${platform.name}</strong>
        <a href="${url}" target="_blank" rel="noopener noreferrer nofollow external" referrerpolicy="no-referrer">${url}</a>
      </div>
    `;
  });

  clearBtn.addEventListener("click", () => {
    input.value = "";
    preview.classList.add("hidden");
    wrapper.classList.remove("valid", "invalid");
    icon.textContent = "🔗";
  });

  // SUBMIT + REDIRECT A TU /gracias
  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    btn.disabled = true;
    btn.textContent = "Enviando...";

    const formData = new FormData(form);

    try {
      const res = await fetch("https://formspree.io/f/xlgaejzd", {
        method: "POST",
        body: formData,
        headers: { Accept: "application/json" }
      });

      if (res.ok) {
        window.location.href = "gracias"; // 🔥 CLAVE
      } else {
        status.textContent = "Error al enviar";
        status.style.color = "#f87171";
      }
    } catch {
      status.textContent = "Error de conexión";
      status.style.color = "#f87171";
    }

    btn.disabled = false;
    btn.textContent = "Enviar mensaje";
  });
</script>

<style>
.link-input-wrapper {
  display: flex;
  align-items: center;
  gap: 8px;
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 10px;
  padding: 8px 10px;
  background: rgba(255,255,255,0.02);
  transition: 0.2s;
}

.link-input-wrapper.valid {
  border-color: rgba(74,222,128,0.6);
}

.link-input-wrapper.invalid {
  border-color: rgba(248,113,113,0.7);
}

.link-icon {
  opacity: 0.7;
}

.clear-link {
  margin-left: auto;
  border: none;
  background: transparent;
  color: rgba(255,255,255,0.4);
  cursor: pointer;
}

.clear-link:hover {
  color: white;
}

.link-preview {
  margin-top: 10px;
  display: flex;
  gap: 10px;
  padding: 10px;
  border-radius: 10px;
  background: rgba(255,255,255,0.03);
  align-items: center;
}

.lp-icon {
  font-size: 18px;
}

.lp-meta strong {
  display: block;
  font-size: 13px;
}

.lp-meta a {
  font-size: 11px;
  opacity: 0.6;
  word-break: break-all;
}

.field-hint {
  display: block;
  margin-top: 6px;
  font-size: 11px;
  opacity: 0.5;
}
</style>