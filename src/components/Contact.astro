---
// Contact.astro
---

<section id="contacto" class="section section-dark">
  <div class="wrap">
    <span class="sec-label">// 04</span>
    <h2 class="sec-title">Contacto</h2>
    <p class="sec-sub">Si tienes una oportunidad de FCT o simplemente quieres hablar de un proyecto.</p>

    <div class="contact-grid">
      <div class="contact-links">
        <a href="mailto:villegasriveraluis@gmail.com" class="contact-link">
          <span class="cl-label">email</span>
          <span class="cl-val">villegasriveraluis@gmail.com</span>
        </a>
        <a href="https://github.com/LuisVilRiv" target="_blank" rel="noopener noreferrer" class="contact-link">
          <span class="cl-label">github</span>
          <span class="cl-val">LuisVilRiv</span>
        </a>
        <a href="https://www.linkedin.com/in/luis-villegas-rivera/" target="_blank" rel="noopener noreferrer" class="contact-link">
          <span class="cl-label">linkedin</span>
          <span class="cl-val">luis-villegas-rivera</span>
        </a>
        <div class="contact-link" style="cursor:default">
          <span class="cl-label">ubicación</span>
          <span class="cl-val">Granada, España</span>
        </div>
      </div>

      <!--
        Formulario con Formspree — funciona sin backend.
        Pasos para activarlo:
          1. Regístrate gratis en https://formspree.io
          2. Crea un nuevo form con tu email
          3. Sustituye "TU_FORM_ID" por el ID que te dan (p.ej. xpzgwkqr)
      -->
      <form
        class="contact-form"
        action="https://formspree.io/f/TU_FORM_ID"
        method="POST"
      >
        <div class="field">
          <label for="nombre">Nombre</label>
          <input id="nombre" name="nombre" type="text" placeholder="Tu nombre" required />
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" placeholder="tu@email.com" required />
        </div>
        <div class="field">
          <label for="mensaje">Mensaje</label>
          <textarea id="mensaje" name="mensaje" rows="5" placeholder="De qué va..." required></textarea>
        </div>
        <!-- Honeypot anti-spam de Formspree -->
        <input type="text" name="_gotcha" style="display:none" />
        <button type="submit" class="btn btn-full">Enviar mensaje</button>
      </form>
    </div>
  </div>
</section>
