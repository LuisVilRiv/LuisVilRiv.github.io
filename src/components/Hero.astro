---
// Hero.astro
// The photo is referenced from /public/foto.jpg — copy your photo there.
---

<section class="hero" id="inicio">
  <div class="hero-text">
    <div class="hero-badge">
      <span class="hero-dot"></span>
      Disponible FCT 2027 &nbsp;·&nbsp; Granada, España
    </div>

    <h1>
      Luis<br/>
      <span class="name-accent" data-text="Villegas">Villegas</span><br/>
      Rivera
    </h1>

    <p class="hero-desc">
      DAW + ASIR. Tengo conocimientos en web, backend y sistemas<br/>
      — desde la base.
    </p>

    <div class="hero-btns">
      <a href="#proyectos" class="btn">Ver proyectos</a>
      <a href="#contacto" class="btn-ghost">Contactar</a>
    </div>
  </div>

  <div class="hero-photo">
    <span class="photo-corner tl"></span>
    <span class="photo-corner tr"></span>
    <span class="photo-corner bl"></span>
    <div class="photo-frame">
      <img src="/foto.jpg" alt="Luis Villegas Rivera" width="280" height="330" />
    </div>
    <div class="photo-badge">
      <span class="label">nota media DAW</span>
      <strong class="value">9.0</strong>
    </div>
  </div>
</section>
